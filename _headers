/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Long cache for static assets (images, fonts, JS) — these rarely change
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stylesheet + consent script: revalidate on every load so edits ship WITHOUT a
# version bump. (More specific path wins over /assets/* above.) The browser sends an
# ETag check and gets a tiny 304 when unchanged, or the new file when it changed.
# This is why future CSS tweaks (and setting the real GA4 ID in consent.js) are
# 1-2 file commits, not a site-wide ?v= bump.
/assets/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/assets/consent.js
  Cache-Control: public, max-age=0, must-revalidate
